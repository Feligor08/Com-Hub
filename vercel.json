{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/support-chat",
      "destination": "/api/support-chat.js"
    },
    {
      "source": "/global/(.*)",
      "destination": "/global/$1"
    },
    {
      "source": "/private/(.*)",
      "destination": "/private/$1"
    },
    {
      "source": "/seiten/(.*)",
      "destination": "/seiten/$1"
    },
    {
      "source": "/",
      "destination": "/seiten/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/seiten/$1"
    }
  ]
}